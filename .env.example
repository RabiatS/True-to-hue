# --- Browser / Vite (local development only) ---
# Never commit .env.local. VITE_* values are embedded in the JS bundle — do not use VITE_OPENAI_API_KEY for production builds.

# Optional: direct OpenAI from the dev server only (npm run dev). Not used in production.
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4.1-mini

# Public theme API base URL (no trailing slash), after you deploy server/theme-proxy.ts.
# For GitHub Actions production builds, set the same value as repository variable VITE_THEME_API_URL
VITE_THEME_API_URL=

# --- Theme proxy server (server/theme-proxy.ts) — keep secrets here, not in Vite ---
# OPENAI_API_KEY= (set only on the server host, never in Vite)
# OPENAI_MODEL=gpt-4.1-mini
# PORT=8787
# Optional: restrict browser callers (comma-separated URL prefixes)
# ALLOWED_ORIGINS=http://localhost:3000,https://rabiats.github.io,https://YOUR_DOMAIN
