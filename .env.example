# The live app uses "bring your own key" in the browser (OpenAI, Gemini, or Claude) via the API key button.
# Optional: use .env.local for dev-only shortcuts (never commit .env.local).

# --- Optional dev shortcuts (npm run dev) — still embedded in dev bundle only if set ---
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4.1-mini

# Optional: hosted theme proxy base URL (no trailing slash). See DEPLOY-PROXY.md
VITE_THEME_API_URL=

# --- Theme proxy server (server/theme-proxy.ts) — keep secrets on the host only ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# PORT=8787
# ALLOWED_ORIGINS=http://localhost:3000,https://rabiats.github.io
